# Backend Environment Variables

# Database
DATABASE_URL=postgres://user:pass@localhost:5432/arenax
BACKEND_MIGRATION_MODE=run
REDIS_URL=redis://localhost:6379

# Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=secret
S3_BUCKET=arenax

# Payments
PAYSTACK_SECRET=sk_test_xxx
FLUTTERWAVE_SECRET=FLWSECK_TEST-xxx

# Authentication
JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=7d

# Stellar Configuration
STELLAR_NETWORK_URL=https://horizon-testnet.stellar.org
# [REQUIRED SECRET] Your Stellar admin account secret key (starts with S, 56 chars).
STELLAR_ADMIN_SECRET=
# [REQUIRED SECRET] AES-256-GCM key for encrypting Stellar secret keys at rest.
# Generate with: openssl rand -hex 32
STELLAR_ENCRYPTION_KEY=
SOROBAN_CONTRACT_PRIZE=
SOROBAN_CONTRACT_REPUTATION=
SOROBAN_CONTRACT_ARENAX_TOKEN=

# AI
AI_MODEL_PATH=./models/anti_cheat.tflite

# Server Configuration
PORT=8080
HOST=0.0.0.0
RUST_LOG=info

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
