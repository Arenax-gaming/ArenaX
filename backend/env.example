# Backend Environment Variables
# ============================================================
# Variables marked [REQUIRED SECRET] MUST be set to strong,
# randomly-generated values before starting the application.
# The application will refuse to start if any required secret
# is missing, empty, or matches a known placeholder value.
# ============================================================

# Database
DATABASE_URL=postgres://user:pass@localhost:5432/arenax

# Redis
REDIS_URL=redis://localhost:6379

# Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
# [REQUIRED SECRET] Minimum 8 characters. Generate with: openssl rand -hex 32
S3_SECRET_KEY=

# Payments
# [REQUIRED SECRET] Minimum 16 characters. Use your live/test key from Paystack dashboard.
PAYSTACK_SECRET=
# [REQUIRED SECRET] Minimum 16 characters. Use your live/test key from Flutterwave dashboard.
FLUTTERWAVE_SECRET=

# Authentication
# [REQUIRED SECRET] Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Stellar Configuration
STELLAR_NETWORK_URL=https://horizon-testnet.stellar.org
# [REQUIRED SECRET] Minimum 32 characters. Your Stellar admin account secret key (starts with S).
STELLAR_ADMIN_SECRET=
SOROBAN_CONTRACT_PRIZE=
SOROBAN_CONTRACT_REPUTATION=
SOROBAN_CONTRACT_ARENAX_TOKEN=

# AI
AI_MODEL_PATH=./models/anti_cheat.tflite

# Server Configuration
PORT=8080
HOST=0.0.0.0
RUST_LOG=info

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
