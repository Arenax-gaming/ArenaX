generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  role          String    @default("USER")
  isVerified    Boolean   @default(false)
  bio           String?
  socials       Json?
  walletAddress String?   @unique
  verificationToken        String?   @unique
  verificationTokenExpires DateTime?
  passwordResetToken      String?   @unique
  passwordResetExpires   DateTime?
  provider               String?   @default("EMAIL")
  providerId             String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  projects      Project[]
  wallet        UserWallet?
  refreshTokens RefreshToken[]
  ledger        Ledger?
  walletTransactions WalletTransaction[]
  proposals     Proposal[] @relation("UserProposals")
  votes         Vote[]     @relation("UserVotes")
  reportedDisputes Dispute[] @relation("ReportedDisputes")
  resolvedDisputes Dispute[] @relation("ResolvedDisputes")
  auditLogs     AuditLog[]
  refundsReviewed RefundRequest[] @relation("OperatorReviews")
  kycReview     KycReview?
  reviewedKycs  KycReview[]     @relation("ReviewerKyc")
  walletKeyAccessAudits    WalletKeyAccessAudit[]    @relation("WalletKeyAccessActor")
  walletRecoveryChallenges WalletRecoveryChallenge[]
  bans                     Ban[] @relation("UserBans")
  adminBans                Ban[] @relation("AdminBans")
  reportedModerations      ModerationItem[] @relation("ReportedModerations")
  reviewedModerations      ModerationItem[] @relation("ReviewedModerations")
  playerAchievements       PlayerAchievement[]
  achievementShares        AchievementShare[]
  achievementNotifications AchievementNotification[]
  hostedSessions           GameSession[]
  gameSessionParticipations GameSessionPlayer[]
  tournamentParticipations TournamentParticipant[]
  tournamentRegistrations  TournamentRegistration[]
  organizedTournaments     Tournament[]
  leaderboardEntries       LeaderboardEntry[]

  @@index([deletedAt])
  @@index([provider])
  @@index([providerId])
  @@index([verificationToken])
  @@index([passwordResetToken])
}

enum AchievementCategory {
  COMBAT
  SOCIAL
  PROGRESSION
  SEASONAL
}

model Achievement {
  id           String                @id @default(uuid())
  key          String                @unique
  name         String
  description  String
  category     AchievementCategory
  targetValue  Int                   @default(1)
  eventTypes   String[]
  rewards      Json                  @default("{}")
  hidden       Boolean               @default(false)
  sortOrder    Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  deletedAt    DateTime?
  playerProgress PlayerAchievement[]
  shares       AchievementShare[]
  notifications AchievementNotification[]

  @@index([category])
  @@index([deletedAt])
}

model PlayerAchievement {
  id              String    @id @default(uuid())
  userId          String
  achievementId   String
  progress        Int       @default(0)
  unlockedAt      DateTime?
  rewardClaimedAt DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

model AchievementShare {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  shareSlug     String   @unique
  caption       String?
  platform      String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([achievementId])
}

model AchievementNotification {
  id              String    @id @default(uuid())
  userId          String
  achievementId   String
  type            String
  payload         Json?
  readAt          DateTime?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([achievementId])
}

model UserWallet {
  id                 String    @id @default(uuid())
  userId             String    @unique
  publicKey          String    @unique
  encryptedSecretKey String
  encryptionVersion  Int       @default(1)
  lastRotatedAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  keyAccessAudits    WalletKeyAccessAudit[]
  recoveryChallenges WalletRecoveryChallenge[]
}

model RefreshToken {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId          String
  tokenHash         String   @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  parentTokenId     String?
  replacedByTokenId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([familyId])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  payments    Payment[]
}

model Payment {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  fromAddress String
  toAddress   String
  amount      String
  asset       String   @default("USDC")
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED, DEAD_LETTER
  txHash      String?  @unique
  retryCount  Int      @default(0)
  nextRetryAt DateTime?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  refundRequests RefundRequest[]
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
}

enum Currency {
  XLM
  USDC
  AX
}

enum TransactionType {
  CREDIT
  DEBIT
  ESCROW_LOCK
  ESCROW_RELEASE
  ESCROW_SLASH
  PLATFORM_FEE
  PRIZE_POOL_FUND
}

// High-precision financial ledger per user per currency
model Ledger {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  xlmBalance    Decimal  @default(0) @db.Decimal(20, 7)
  xlmEscrowed   Decimal  @default(0) @db.Decimal(20, 7)
  usdcBalance   Decimal  @default(0) @db.Decimal(20, 7)
  usdcEscrowed  Decimal  @default(0) @db.Decimal(20, 7)
  axBalance     Decimal  @default(0) @db.Decimal(20, 7)
  axEscrowed    Decimal  @default(0) @db.Decimal(20, 7)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Admin related models
model Ban {
  id         String   @id @default(uuid())
  userId     String
  adminId    String?
  reason     String
  bannedAt   DateTime @default(now())
  unbannedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation("UserBans", fields: [userId], references: [id], onDelete: Cascade)
  admin User? @relation("AdminBans", fields: [adminId], references: [id])

  @@index([userId])
  @@index([adminId])
}

model GameConfig {
  id                 String   @id @default(uuid())
  maintenanceMode    Boolean  @default(false)
  maxPlayersPerMatch Int      @default(8)
  minPlayersToStart  Int      @default(2)
  matchTimeout       Int      @default(3600)
  dailyMatchLimit    Int      @default(100)
  updatedAt          DateTime @updatedAt
}

enum ModerationStatus {
  PENDING
  REVIEWED
  ACTIONED
}

model ModerationItem {
  id             String           @id @default(uuid())
  type           String
  reportedUserId String
  content        String
  reportedAt     DateTime         @default(now())
  status         ModerationStatus @default(PENDING)
  flagged        Boolean          @default(false)
  flagReason     String?
  severity       String           @default("LOW")
  reviewerId     String?
  reviewedAt     DateTime?
  actionTaken    String?

  reportedUser User @relation("ReportedModerations", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reviewer     User? @relation("ReviewedModerations", fields: [reviewerId], references: [id])

  @@index([reportedUserId])
  @@index([status])
  @@index([severity])
}

// Immutable transaction history with idempotency key
model WalletTransaction {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  idempotencyKey String          @unique
  type           TransactionType
  currency       Currency
  amount         Decimal         @db.Decimal(20, 7)
  balanceBefore  Decimal         @db.Decimal(20, 7)
  balanceAfter   Decimal         @db.Decimal(20, 7)
  escrowBefore   Decimal         @db.Decimal(20, 7)
  escrowAfter    Decimal         @db.Decimal(20, 7)
  matchId        String?
  note           String?
  createdAt      DateTime        @default(now())

  @@index([userId])
  @@index([idempotencyKey])
  @@index([matchId])
}

model BlockchainTransaction {
  id        String   @id @default(uuid())
  userId    String?
  txHash    String   @unique
  type      String   // e.g., "WALLET_REGISTRATION", "CONTRACT_INVOKE"
  status    TxStatus @default(PENDING)
  payload   Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlockchainEvent {
  id            String   @id @default(uuid())
  eventType     String // e.g., PAY_DONE
  namespace     String
  schemaVersion String
  contractId    String
  txHash        String
  ledger        Int
  data          Json
  createdAt     DateTime @default(now())

  @@index([namespace, schemaVersion, eventType])
}

enum WalletKeyAccessAction {
  SIGN
  EXPORT
  RECOVERY_CHALLENGE_CREATED
  RECOVERY_CHALLENGE_COMPLETED
  ROTATION
}

enum WalletRecoveryChallengeStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELLED
}

model WalletKeyAccessAudit {
  id           String                @id @default(uuid())
  walletId     String
  actorUserId  String?
  action       WalletKeyAccessAction
  success      Boolean               @default(true)
  requestId    String?
  ipAddress    String?
  userAgent    String?
  reason       String?
  keyVersion   Int?
  metadata     Json?
  previousHash String?
  entryHash    String                @unique
  createdAt    DateTime              @default(now())

  wallet UserWallet @relation(fields: [walletId], references: [id], onDelete: Restrict)
  actor  User?      @relation("WalletKeyAccessActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([actorUserId, createdAt])
}

model WalletRecoveryChallenge {
  id                 String                        @id @default(uuid())
  userId             String
  walletId           String
  codeHash           String
  expiresAt          DateTime
  completedAt        DateTime?
  status             WalletRecoveryChallengeStatus @default(PENDING)
  attempts           Int                           @default(0)
  maxAttempts        Int                           @default(5)
  requestId          String?
  requestedFromIp    String?
  requestedUserAgent String?
  lastAttemptAt      DateTime?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
  @@index([walletId, status])
}

enum ProposalStatus {
  DRAFT
  VOTING
  APPROVED
  EXECUTED
  CANCELLED
  FAILED
}

model Proposal {
  id             String         @id @default(uuid())
  onChainId      String?        @unique // Map to hex-encoded 32 bytes on-chain
  targetContract String
  functionName   String
  args           Json           @default("{}")
  description    String?
  status         ProposalStatus @default(DRAFT)
  proposerId     String
  proposer       User           @relation("UserProposals", fields: [proposerId], references: [id])
  executeAfter   DateTime?
  executedAt     DateTime?
  lastChainTx    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  votes          Vote[]

  @@index([status])
  @@index([proposerId])
}

model Vote {
  id         String   @id @default(uuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voterId    String
  voter      User     @relation("UserVotes", fields: [voterId], references: [id])
  signature  String?  // If multisig requires signatures
  chainTx    String?
  createdAt  DateTime @default(now())

  @@unique([proposalId, voterId])
}

enum MatchStatus {
  CREATED
  STARTED
  COMPLETED
  DISPUTED
  FINALIZED
}

model Match {
  id             String      @id @default(uuid())
  onChainId      String      @unique
  playerAId      String
  playerBId      String
  winnerId       String?
  status         MatchStatus @default(CREATED)
  metadata       Json        @default("{}")
  lastChainTx    String?
  createdAt      DateTime    @default(now())
  startedAt      DateTime?
  endedAt        DateTime?
  updatedAt      DateTime    @updatedAt
  disputes       Dispute[]

  @@index([status])
}

model Dispute {
  id           String   @id @default(uuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reporterId   String
  reporter     User     @relation("ReportedDisputes", fields: [reporterId], references: [id])
  reason       String
  evidenceUrls String[] // Array of S3/MinIO links
  status       String   @default("OPEN") // OPEN, RESOLVED, DISMISSED
  resolution   String?
  resolvedById String?
  resolvedBy   User?    @relation("ResolvedDisputes", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String   // e.g., "MATCH_OVERRIDE", "PROPOSAL_EXECUTE", "MANUAL_PAYOUT"
  targetType String   // e.g., "MATCH", "PROPOSAL", "USER"
  targetId   String
  details        Json?
  requestId      String?
  snapshotBefore Json?
  snapshotAfter  Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([requestId])
}

enum RefundStatus {
  REQUESTED
  REVIEWING
  APPROVED
  REJECTED
  PROCESSED
}

model RefundRequest {
  id            String       @id @default(uuid())
  paymentId     String
  payment       Payment      @relation(fields: [paymentId], references: [id])
  amount        String
  status        RefundStatus @default(REQUESTED)
  reason        String
  operatorId    String?
  operator      User?        @relation("OperatorReviews", fields: [operatorId], references: [id])
  operatorNotes String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([paymentId])
  @@index([status])
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

model KycReview {
  id           String    @id @default(uuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       KycStatus @default(PENDING)
  documents    Json      @default("[]") // URLs and metadata
  notes        String?
  reviewerId   String?
  reviewer     User?     @relation("ReviewerKyc", fields: [reviewerId], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
}

// Game Mode Model
enum GameModeType {
  ONE_V_ONE
  TWO_V_TWO
  THREE_V_THREE
  FOUR_V_FOUR
  FIVE_V_FIVE
  FREE_FOR_ALL
  TEAM_DEATHMATCH
  CAPTURE_THE_FLAG
}

model GameMode {
  id          String       @id @default(uuid())
  name        String       @unique
  displayName String
  type        GameModeType
  description String?
  maxPlayers  Int
  minPlayers  Int
  rules       Json         @default("{}")
  settings    Json         @default("{}")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  tournaments Tournament[]
  gameSessions GameSession[]
  leaderboards Leaderboard[]

  @@index([type])
  @@index([isActive])
}

// Leaderboard Models
enum LeaderboardType {
  GLOBAL
  GAME_MODE
  SEASON
  EVENT
}

model Leaderboard {
  id          String            @id @default(uuid())
  name        String
  type        LeaderboardType
  gameModeId  String?
  gameMode    GameMode?         @relation(fields: [gameModeId], references: [id])
  season      Int?
  isActive    Boolean           @default(true)
  startDate   DateTime
  endDate     DateTime?
  metadata    Json              @default("{}")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  entries     LeaderboardEntry[]

  @@index([type])
  @@index([gameModeId])
  @@index([isActive])
  @@index([season])
}

model LeaderboardEntry {
  id            String     @id @default(uuid())
  leaderboardId String
  leaderboard   Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  rank          Int
  score         Decimal    @default(0) @db.Decimal(20, 7)
  wins          Int        @default(0)
  losses        Int        @default(0)
  draws         Int        @default(0)
  winRate       Decimal    @default(0) @db.Decimal(5, 4)
  gamesPlayed   Int        @default(0)
  metadata      Json       @default("{}")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([leaderboardId, userId])
  @@index([leaderboardId])
  @@index([userId])
  @@index([rank])
}

// Match History Model
model MatchHistory {
  id           String      @id @default(uuid())
  gameSessionId String?
  gameSession  GameSession? @relation(fields: [gameSessionId], references: [id])
  playerAId    String
  playerBId    String
  winnerId     String?
  scoreA       Int
  scoreB       Int
  duration     Int
  analytics    Json        @default("{}")
  metadata     Json        @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  @@index([gameSessionId])
  @@index([playerAId])
  @@index([playerBId])
  @@index([winnerId])
  @@index([createdAt])
}

// Tournament and Game Session Models
enum TournamentFormat {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  SWISS
}

enum TournamentStatus {
  PENDING
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TournamentRound {
  QUALIFICATION
  ROUND_OF_64
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  FINAL
  GRAND_FINAL
}

enum MatchResultType {
  WIN
  LOSS
  DRAW
  BYE
  DISQUALIFIED
}

enum GameSessionStatus {
  CREATED
  WAITING_FOR_PLAYERS
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
  TIMEOUT
}

enum GameSessionType {
  CASUAL
  RANKED
  TOURNAMENT
  CUSTOM
}

model Tournament {
  id                String            @id @default(uuid())
  name              String
  description       String?
  format            TournamentFormat
  status            TournamentStatus  @default(PENDING)
  gameId            String
  gameModeId        String
  gameMode          GameMode          @relation(fields: [gameModeId], references: [id])
  maxPlayers        Int
  minPlayers        Int               @default(2)
  entryFee          Decimal?          @db.Decimal(20, 7)
  prizePool         Decimal           @default(0) @db.Decimal(20, 7)
  prizeDistribution Json              @default("{}")
  registrationStart DateTime
  registrationEnd   DateTime
  startDate         DateTime
  endDate           DateTime?
  checkInWindow     Int               @default(15)
  organizerId       String
  organizer         User              @relation(fields: [organizerId], references: [id])
  currentRound      Int               @default(0)
  totalRounds       Int               @default(0)
  settings          Json              @default("{}")
  metadata          Json              @default("{}")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  participants      TournamentParticipant[]
  matches           TournamentMatch[]
  registrations     TournamentRegistration[]

  @@index([status])
  @@index([gameId])
  @@index([gameModeId])
  @@index([organizerId])
  @@index([startDate])
}

model TournamentParticipant {
  id                String     @id @default(uuid())
  tournamentId      String
  tournament        Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  seed              Int?
  checkedIn         Boolean    @default(false)
  checkedInAt       DateTime?
  status            String     @default("REGISTERED")
  eliminatedAt      DateTime?
  eliminatedRound   Int?
  wins              Int        @default(0)
  losses            Int        @default(0)
  draws             Int        @default(0)
  points            Decimal    @default(0) @db.Decimal(20, 7)
  prizeAmount       Decimal?  @db.Decimal(20, 7)
  metadata          Json       @default("{}")
  registeredAt      DateTime   @default(now())
  deletedAt         DateTime?
  matchesAsPlayerA  TournamentMatch[] @relation("MatchPlayerA")
  matchesAsPlayerB  TournamentMatch[] @relation("MatchPlayerB")
  matchesAsWinner   TournamentMatch[] @relation("MatchWinner")

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
  @@index([status])
  @@index([deletedAt])
}

model TournamentMatch {
  id                String     @id @default(uuid())
  tournamentId      String
  tournament        Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round             Int
  roundName         TournamentRound
  matchNumber       Int
  playerAId         String?
  playerA           TournamentParticipant? @relation("MatchPlayerA", fields: [playerAId], references: [id])
  playerBId         String?
  playerB           TournamentParticipant? @relation("MatchPlayerB", fields: [playerBId], references: [id])
  winnerId          String?
  winner            TournamentParticipant? @relation("MatchWinner", fields: [winnerId], references: [id])
  playerAScore      Int        @default(0)
  playerBScore      Int        @default(0)
  resultType        MatchResultType?
  status            String     @default("PENDING")
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  matchId           String?
  metadata          Json       @default("{}")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  @@index([tournamentId])
  @@index([round])
  @@index([status])
  @@index([playerAId])
  @@index([playerBId])
  @@index([deletedAt])
}

model TournamentRegistration {
  id                String     @id @default(uuid())
  tournamentId      String
  tournament        Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            String     @default("PENDING")
  waitlistPosition  Int?
  paymentStatus     String     @default("PENDING")
  paymentTxHash     String?
  metadata          Json       @default("{}")
  registeredAt      DateTime   @default(now())
  confirmedAt       DateTime?

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
  @@index([status])
}

model GameSession {
  id                String            @id @default(uuid())
  gameId            String
  gameModeId        String
  gameMode          GameMode          @relation(fields: [gameModeId], references: [id])
  sessionType       GameSessionType   @default(CASUAL)
  status            GameSessionStatus @default(CREATED)
  hostId            String
  host              User              @relation(fields: [hostId], references: [id])
  maxPlayers        Int               @default(2)
  minPlayers        Int               @default(2)
  currentState      Json              @default("{}")
  initialState      Json              @default("{}")
  settings          Json              @default("{}")
  replayData        Json?
  metadata          Json              @default("{}")
  startedAt         DateTime?
  endedAt           DateTime?
  duration          Int?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  players           GameSessionPlayer[]
  actions           GameSessionAction[]
  events            GameSessionEvent[]
  matchHistories    MatchHistory[]

  @@index([status])
  @@index([gameId])
  @@index([gameModeId])
  @@index([hostId])
  @@index([sessionType])
}

model GameSessionPlayer {
  id                String         @id @default(uuid())
  sessionId         String
  session           GameSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  playerNumber      Int
  team              String?
  score             Int            @default(0)
  rank              Int?
  rating            Decimal?       @db.Decimal(20, 7)
  ratingChange      Decimal?       @db.Decimal(20, 7)
  status            String         @default("ACTIVE")
  disconnectedAt    DateTime?
  reconnectedAt     DateTime?
  joinedAt          DateTime       @default(now())
  leftAt            DateTime?
  metadata          Json           @default("{}")
  deletedAt         DateTime?
  actions           GameSessionAction[]

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@index([deletedAt])
}

model GameSessionAction {
  id                String      @id @default(uuid())
  sessionId         String
  session           GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId          String
  player            GameSessionPlayer @relation(fields: [playerId], references: [id])
  actionType        String
  data              Json        @default("{}")
  timestamp         DateTime    @default(now())
  validated         Boolean     @default(false)
  metadata          Json        @default("{}")

  @@index([sessionId])
  @@index([playerId])
  @@index([timestamp])
}

model GameSessionEvent {
  id                String      @id @default(uuid())
  sessionId         String
  session           GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType         String
  data              Json        @default("{}")
  timestamp         DateTime    @default(now())
  metadata          Json        @default("{}")

  @@index([sessionId])
  @@index([eventType])
  @@index([timestamp])
}
