generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  role          String    @default("USER")
  isVerified    Boolean   @default(false)
  bio           String?
  socials       Json?
  walletAddress String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]
  wallet        UserWallet?
  refreshTokens RefreshToken[]
  ledger        Ledger?
  walletTransactions WalletTransaction[]
  proposals     Proposal[] @relation("UserProposals")
  votes         Vote[]     @relation("UserVotes")
  reportedDisputes Dispute[] @relation("ReportedDisputes")
  resolvedDisputes Dispute[] @relation("ResolvedDisputes")
  auditLogs     AuditLog[]
  refundsReviewed RefundRequest[] @relation("OperatorReviews")
  kycReview     KycReview?
  reviewedKycs  KycReview[]     @relation("ReviewerKyc")
  walletKeyAccessAudits    WalletKeyAccessAudit[]    @relation("WalletKeyAccessActor")
  walletRecoveryChallenges WalletRecoveryChallenge[]
  playerAchievements       PlayerAchievement[]
  achievementShares        AchievementShare[]
  achievementNotifications AchievementNotification[]
  gameSessionParticipants  GameSessionParticipant[]
  tournamentParticipants   TournamentParticipant[]
  leaderboardEntries       LeaderboardEntry[]

}

enum AchievementCategory {
  COMBAT
  SOCIAL
  PROGRESSION
  SEASONAL
}

model Achievement {
  id           String                @id @default(uuid())
  key          String                @unique
  name         String
  description  String
  category     AchievementCategory
  targetValue  Int                   @default(1)
  eventTypes   String[]
  rewards      Json                  @default("{}")
  hidden       Boolean               @default(false)
  sortOrder    Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  playerProgress PlayerAchievement[]
  shares       AchievementShare[]
  notifications AchievementNotification[]

  @@index([category])
}

model PlayerAchievement {
  id              String    @id @default(uuid())
  userId          String
  achievementId   String
  progress        Int       @default(0)
  unlockedAt      DateTime?
  rewardClaimedAt DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

model AchievementShare {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  shareSlug     String   @unique
  caption       String?
  platform      String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([achievementId])
}

model AchievementNotification {
  id              String    @id @default(uuid())
  userId          String
  achievementId   String
  type            String
  payload         Json?
  readAt          DateTime?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([achievementId])
}

model UserWallet {
  id                 String    @id @default(uuid())
  userId             String    @unique
  publicKey          String    @unique
  encryptedSecretKey String
  encryptionVersion  Int       @default(1)
  lastRotatedAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  keyAccessAudits    WalletKeyAccessAudit[]
  recoveryChallenges WalletRecoveryChallenge[]
}

model RefreshToken {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId          String
  tokenHash         String   @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  parentTokenId     String?
  replacedByTokenId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([familyId])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  payments    Payment[]
}

model Payment {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  fromAddress String
  toAddress   String
  amount      String
  asset       String   @default("USDC")
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED, DEAD_LETTER
  txHash      String?  @unique
  retryCount  Int      @default(0)
  nextRetryAt DateTime?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  refundRequests RefundRequest[]
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
}

enum Currency {
  XLM
  USDC
  AX
}

enum TransactionType {
  CREDIT
  DEBIT
  ESCROW_LOCK
  ESCROW_RELEASE
  ESCROW_SLASH
  PLATFORM_FEE
  PRIZE_POOL_FUND
}

// High-precision financial ledger per user per currency
model Ledger {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  xlmBalance    Decimal  @default(0) @db.Decimal(20, 7)
  xlmEscrowed   Decimal  @default(0) @db.Decimal(20, 7)
  usdcBalance   Decimal  @default(0) @db.Decimal(20, 7)
  usdcEscrowed  Decimal  @default(0) @db.Decimal(20, 7)
  axBalance     Decimal  @default(0) @db.Decimal(20, 7)
  axEscrowed    Decimal  @default(0) @db.Decimal(20, 7)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Immutable transaction history with idempotency key
model WalletTransaction {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  idempotencyKey String          @unique
  type           TransactionType
  currency       Currency
  amount         Decimal         @db.Decimal(20, 7)
  balanceBefore  Decimal         @db.Decimal(20, 7)
  balanceAfter   Decimal         @db.Decimal(20, 7)
  escrowBefore   Decimal         @db.Decimal(20, 7)
  escrowAfter    Decimal         @db.Decimal(20, 7)
  matchId        String?
  note           String?
  createdAt      DateTime        @default(now())

  @@index([userId])
  @@index([idempotencyKey])
  @@index([matchId])
}

model BlockchainTransaction {
  id        String   @id @default(uuid())
  userId    String?
  txHash    String   @unique
  type      String   // e.g., "WALLET_REGISTRATION", "CONTRACT_INVOKE"
  status    TxStatus @default(PENDING)
  payload   Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlockchainEvent {
  id            String   @id @default(uuid())
  eventType     String // e.g., PAY_DONE
  namespace     String
  schemaVersion String
  contractId    String
  txHash        String
  ledger        Int
  data          Json
  createdAt     DateTime @default(now())

  @@index([namespace, schemaVersion, eventType])
}

enum WalletKeyAccessAction {
  SIGN
  EXPORT
  RECOVERY_CHALLENGE_CREATED
  RECOVERY_CHALLENGE_COMPLETED
  ROTATION
}

enum WalletRecoveryChallengeStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELLED
}

model WalletKeyAccessAudit {
  id           String                @id @default(uuid())
  walletId     String
  actorUserId  String?
  action       WalletKeyAccessAction
  success      Boolean               @default(true)
  requestId    String?
  ipAddress    String?
  userAgent    String?
  reason       String?
  keyVersion   Int?
  metadata     Json?
  previousHash String?
  entryHash    String                @unique
  createdAt    DateTime              @default(now())

  wallet UserWallet @relation(fields: [walletId], references: [id], onDelete: Restrict)
  actor  User?      @relation("WalletKeyAccessActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([actorUserId, createdAt])
}

model WalletRecoveryChallenge {
  id                 String                        @id @default(uuid())
  userId             String
  walletId           String
  codeHash           String
  expiresAt          DateTime
  completedAt        DateTime?
  status             WalletRecoveryChallengeStatus @default(PENDING)
  attempts           Int                           @default(0)
  maxAttempts        Int                           @default(5)
  requestId          String?
  requestedFromIp    String?
  requestedUserAgent String?
  lastAttemptAt      DateTime?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
  @@index([walletId, status])
}

enum ProposalStatus {
  DRAFT
  VOTING
  APPROVED
  EXECUTED
  CANCELLED
  FAILED
}

model Proposal {
  id             String         @id @default(uuid())
  onChainId      String?        @unique // Map to hex-encoded 32 bytes on-chain
  targetContract String
  functionName   String
  args           Json           @default("{}")
  description    String?
  status         ProposalStatus @default(DRAFT)
  proposerId     String
  proposer       User           @relation("UserProposals", fields: [proposerId], references: [id])
  executeAfter   DateTime?
  executedAt     DateTime?
  lastChainTx    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  votes          Vote[]

  @@index([status])
  @@index([proposerId])
}

model Vote {
  id         String   @id @default(uuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voterId    String
  voter      User     @relation("UserVotes", fields: [voterId], references: [id])
  signature  String?  // If multisig requires signatures
  chainTx    String?
  createdAt  DateTime @default(now())

  @@unique([proposalId, voterId])
}

enum MatchStatus {
  CREATED
  STARTED
  COMPLETED
  DISPUTED
  FINALIZED
  CANCELLED
}

model Match {
  id             String      @id @default(uuid())
  onChainId      String      @unique
  playerAId      String
  playerBId      String
  winnerId       String?
  status         MatchStatus @default(CREATED)
  metadata       Json        @default("{}")
  lastChainTx    String?
  createdAt      DateTime    @default(now())
  startedAt      DateTime?
  endedAt        DateTime?
  updatedAt      DateTime    @updatedAt
  disputes       Dispute[]
  gameSession    GameSession?

  @@index([status])
  @@index([playerAId])
  @@index([playerBId])
  @@index([winnerId])
  @@index([createdAt])
}

model Dispute {
  id           String   @id @default(uuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reporterId   String
  reporter     User     @relation("ReportedDisputes", fields: [reporterId], references: [id])
  reason       String
  evidenceUrls String[] // Array of S3/MinIO links
  status       String   @default("OPEN") // OPEN, RESOLVED, DISMISSED
  resolution   String?
  resolvedById String?
  resolvedBy   User?    @relation("ResolvedDisputes", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String   // e.g., "MATCH_OVERRIDE", "PROPOSAL_EXECUTE", "MANUAL_PAYOUT"
  targetType String   // e.g., "MATCH", "PROPOSAL", "USER"
  targetId   String
  details        Json?
  requestId      String?
  snapshotBefore Json?
  snapshotAfter  Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([requestId])
}

enum RefundStatus {
  REQUESTED
  REVIEWING
  APPROVED
  REJECTED
  PROCESSED
}

model RefundRequest {
  id            String       @id @default(uuid())
  paymentId     String
  payment       Payment      @relation(fields: [paymentId], references: [id])
  amount        String
  status        RefundStatus @default(REQUESTED)
  reason        String
  operatorId    String?
  operator      User?        @relation("OperatorReviews", fields: [operatorId], references: [id])
  operatorNotes String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([paymentId])
  @@index([status])
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

model KycReview {
  id           String    @id @default(uuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       KycStatus @default(PENDING)
  documents    Json      @default("[]") // URLs and metadata
  notes        String?
  reviewerId   String?
  reviewer     User?     @relation("ReviewerKyc", fields: [reviewerId], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
}

// Game Mode Configuration
enum GameModeType {
  ONE_V_ONE
  TWO_V_TWO
  THREE_V_THREE
  FIVE_V_FIVE
  FREE_FOR_ALL
  TOURNAMENT
}

model GameMode {
  id          String        @id @default(uuid())
  name        String        @unique
  displayName String
  type        GameModeType
  description String?
  maxPlayers  Int           @default(2)
  minPlayers  Int           @default(2)
  rules       Json          @default("{}")
  settings    Json          @default("{}")
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  gameSessions GameSession[]
  tournaments  Tournament[]

  @@index([isActive])
}

// Game Session (Match Data)
enum GameSessionStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  ABANDONED
  DISPUTED
}

model GameSession {
  id          String              @id @default(uuid())
  matchId     String?             @unique
  match       Match?              @relation(fields: [matchId], references: [id], onDelete: SetNull)
  gameModeId  String
  gameMode    GameMode            @relation(fields: [gameModeId], references: [id])
  status      GameSessionStatus   @default(WAITING)
  metadata    Json                @default("{}")
  gameData    Json                @default("{}")
  startedAt   DateTime?
  endedAt     DateTime?
  duration    Int?                // Duration in seconds
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  participants GameSessionParticipant[]
  matchHistory MatchHistory[]

  @@index([status])
  @@index([gameModeId])
  @@index([createdAt])
  @@index([startedAt])
}

model GameSessionParticipant {
  id             String       @id @default(uuid())
  gameSessionId  String
  gameSession    GameSession  @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team           String?      // Team identifier
  score          Int          @default(0)
  kills          Int          @default(0)
  deaths         Int          @default(0)
  assists        Int          @default(0)
  position       Int?         // Final position/ranking
  metadata       Json         @default("{}")
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?

  @@unique([gameSessionId, userId])
  @@index([gameSessionId])
  @@index([userId])
}

// Tournament System
enum TournamentStatus {
  DRAFT
  REGISTRATION
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

enum TournamentFormat {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  SWISS
  GROUP_STAGE
}

model Tournament {
  id              String            @id @default(uuid())
  name            String
  description     String?
  gameModeId      String
  gameMode        GameMode          @relation(fields: [gameModeId], references: [id])
  status          TournamentStatus  @default(DRAFT)
  format          TournamentFormat
  maxParticipants Int
  entryFee        Decimal           @default(0) @db.Decimal(20, 7)
  prizePool       Decimal           @default(0) @db.Decimal(20, 7)
  currency        String            @default("USDC")
  startsAt        DateTime?
  endsAt          DateTime?
  registrationStartsAt DateTime?
  registrationEndsAt   DateTime?
  rules           Json              @default("{}")
  metadata        Json              @default("{}")
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  participants    TournamentParticipant[]
  brackets        TournamentBracket[]

  @@index([status])
  @@index([gameModeId])
  @@index([startsAt])
  @@index([createdBy])
}

model TournamentParticipant {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  registeredAt DateTime   @default(now())
  seed         Int?       // Tournament seed for bracket generation
  metadata     Json       @default("{}")
  eliminatedAt DateTime?

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

model TournamentBracket {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        Int
  matchId      String?    // Reference to Match model
  playerAId    String?
  playerBId    String?
  winnerId     String?
  nextMatchId  String?    // Reference to next match in bracket
  position     Json       @default("{}") // Bracket position data
  metadata     Json       @default("{}")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tournamentId])
  @@index([round])
  @@index([matchId])
}

// Leaderboard System
enum LeaderboardType {
  GLOBAL
  GAME_MODE
  TOURNAMENT
  SEASONAL
}

model Leaderboard {
  id          String          @id @default(uuid())
  name        String          @unique
  type        LeaderboardType
  gameModeId  String?
  tournamentId String?
  season      Int?
  isActive    Boolean         @default(true)
  startDate   DateTime?
  endDate     DateTime?
  metadata    Json            @default("{}")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  entries     LeaderboardEntry[]

  @@index([type])
  @@index([isActive])
  @@index([season])
}

model LeaderboardEntry {
  id           String     @id @default(uuid())
  leaderboardId String
  leaderboard   Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  rank         Int
  score        Int        @default(0)
  wins         Int        @default(0)
  losses       Int        @default(0)
  draws        Int        @default(0)
  winRate      Decimal    @default(0) @db.Decimal(5, 2)
  metadata     Json       @default("{}")
  updatedAt    DateTime   @updatedAt

  @@unique([leaderboardId, userId])
  @@index([leaderboardId])
  @@index([userId])
  @@index([rank])
}

// Match History (Detailed Game Records)
model MatchHistory {
  id             String      @id @default(uuid())
  gameSessionId  String
  gameSession    GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  playerAId      String
  playerBId      String
  winnerId       String?
  scoreA         Int         @default(0)
  scoreB         Int         @default(0)
  duration       Int?        // Duration in seconds
  replayData     Json?       // Replay data for match analysis
  analytics      Json        @default("{}")
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now())

  @@index([gameSessionId])
  @@index([playerAId])
  @@index([playerBId])
  @@index([winnerId])
  @@index([createdAt])
}
