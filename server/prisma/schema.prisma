generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  role          String    @default("USER")
  bio           String?
  socials       Json?
  walletAddress String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]
  wallet        UserWallet?
  refreshTokens RefreshToken[]
  proposals     Proposal[] @relation("UserProposals")
  votes         Vote[]     @relation("UserVotes")
  reportedDisputes Dispute[] @relation("ReportedDisputes")
  resolvedDisputes Dispute[] @relation("ResolvedDisputes")
  auditLogs     AuditLog[]
}

model UserWallet {
  id                 String   @id @default(uuid())
  userId             String   @unique
  publicKey          String   @unique
  encryptedSecretKey String
  encryptionVersion  Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId          String
  tokenHash         String   @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  parentTokenId     String?
  replacedByTokenId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([familyId])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  payments    Payment[]
}

model Payment {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  fromAddress String
  toAddress   String
  amount      String
  asset       String   @default("USDC")
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED
  txHash      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
}

model BlockchainTransaction {
  id        String   @id @default(uuid())
  userId    String?
  txHash    String   @unique
  type      String   // e.g., "WALLET_REGISTRATION", "CONTRACT_INVOKE"
  status    TxStatus @default(PENDING)
  payload   Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlockchainEvent {
  id          String   @id @default(uuid())
  eventType   String   // e.g., PAY_DONE
  contractId  String
  txHash      String
  ledger      Int
  data        Json
  createdAt   DateTime @default(now())
}

enum ProposalStatus {
  DRAFT
  VOTING
  APPROVED
  EXECUTED
  CANCELLED
  FAILED
}

model Proposal {
  id             String         @id @default(uuid())
  onChainId      String?        @unique // Map to hex-encoded 32 bytes on-chain
  targetContract String
  functionName   String
  args           Json           @default("{}")
  description    String?
  status         ProposalStatus @default(DRAFT)
  proposerId     String
  proposer       User           @relation("UserProposals", fields: [proposerId], references: [id])
  executeAfter   DateTime?
  executedAt     DateTime?
  lastChainTx    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  votes          Vote[]

  @@index([status])
  @@index([proposerId])
}

model Vote {
  id         String   @id @default(uuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voterId    String
  voter      User     @relation("UserVotes", fields: [voterId], references: [id])
  signature  String?  // If multisig requires signatures
  chainTx    String?
  createdAt  DateTime @default(now())

  @@unique([proposalId, voterId])
}

enum MatchStatus {
  CREATED
  STARTED
  COMPLETED
  DISPUTED
  FINALIZED
}

model Match {
  id             String      @id @default(uuid())
  onChainId      String      @unique
  playerAId      String
  playerBId      String
  winnerId       String?
  status         MatchStatus @default(CREATED)
  metadata       Json        @default("{}")
  lastChainTx    String?
  createdAt      DateTime    @default(now())
  startedAt      DateTime?
  endedAt        DateTime?
  updatedAt      DateTime    @updatedAt
  disputes       Dispute[]

  @@index([status])
}

model Dispute {
  id           String   @id @default(uuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reporterId   String
  reporter     User     @relation("ReportedDisputes", fields: [reporterId], references: [id])
  reason       String
  evidenceUrls String[] // Array of S3/MinIO links
  status       String   @default("OPEN") // OPEN, RESOLVED, DISMISSED
  resolution   String?
  resolvedById String?
  resolvedBy   User?    @relation("ResolvedDisputes", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String   // e.g., "MATCH_OVERRIDE", "PROPOSAL_EXECUTE", "MANUAL_PAYOUT"
  targetType String   // e.g., "MATCH", "PROPOSAL", "USER"
  targetId   String
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([action])
}
